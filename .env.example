WEATHER_CITY=广州
WEATHER_LATITUDE=23.1291
WEATHER_LONGITUDE=113.2644
WEATHER_API_URL=https://api.open-meteo.com/v1/forecast

# Open-Meteo 默认不需要 API Key。
# 如果以后换成需要 Key 的天气服务，请只在 .env 或 GitHub Secrets 中填写真实 Key。
WEATHER_API_KEY=

# 地图逆地理编码配置。
# 默认优先使用高德地图。MAP_API_KEY 不要写死在代码中。
# 如果把高德 Key 用在前端，请在高德后台设置域名白名单，只允许 GitHub Pages 域名调用。
MAP_PROVIDER=amap
MAP_API_KEY=
MAP_SECURITY_NOTE=请在地图平台设置域名白名单

# 企业微信群机器人 Webhook 地址。
# 真实地址只能放在 .env 或 GitHub Secrets 中，不要提交到公开仓库。
WECOM_WEBHOOK_URL=

# GitHub Pages 网站地址，用于企业微信消息里的查看链接。
SITE_URL=https://dragonzero123.github.io/weather-site/

# 前端定位隐私说明：
# 用户经纬度和详细位置只在浏览器当前页面临时使用。
# 用户位置不会写入 data/weather.json、logs/update-log.md，也不会发送到企业微信群。
